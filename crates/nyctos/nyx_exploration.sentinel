record_exploration_finding
{
  "path": "crates/nyctos/src/main.rs",
  "line": 1035,
  "cap": "DNS_REBIND",
  "endpoint": "all /api/v1/* via operator-configured listen_addr",
  "rationale": "TcpListener::bind uses config.ui.listen_addr verbatim (main.rs:947 resolves from CLI/config; bind at :1035). No Host-header allowlist anywhere in the router (grep for Host/host_header in nyctos-api returns zero hits). If listen_addr is 0.0.0.0 (common foot-gun) or the operator merely visits a malicious page while the daemon is bound to 127.0.0.1, DNS-rebinding resolves attacker-controlled hostnames to 127.0.0.1 after the first response, so subsequent fetches from the foreign origin hit the loopback API with browser-side SOP satisfied. Combined with `?token=` URL-query auth (router.rs:141) and absent CorsLayer, a rebind primitive lets a remote attacker pivot to full API access once any token leaks. Static pass missed because no flow is involved — the gap is the absence of `host == 127.0.0.1 || host == localhost` middleware.",
  "suggested_payload_hint": "DNS server with 5s TTL: first answer = attacker IP, second answer = 127.0.0.1; victim visits http://rebind.example/, JS calls fetch('/api/v1/runs?token=<guess>')."
}

