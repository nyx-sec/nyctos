record_exploration_finding
{
  "path": "crates/nyx-agent-api/src/router.rs",
  "line": 1441,
  "cap": "AUTH_BYPASS",
  "endpoint": "GET /api/v1/events (WebSocket upgrade)",
  "rationale": "events_ws performs no Origin-header check before on_upgrade. WebSockets are not subject to the SOP same-origin restriction that gates fetch(); any cross-origin page the operator visits can open ws://127.0.0.1:<port>/api/v1/events and stream every AgentEvent (scan output, repo paths, finding bodies). The bearer-token gate runs first, but the fallback `?token=` URL-query auth (router.rs:132) means a token leaked via Referer / browser history / TraceLayer logs is enough to mount a Cross-Site WebSocket Hijack. Missed by the static pass because the bypass is a *missing* check, not a tainted-flow sink.",
  "suggested_payload_hint": "from a non-loopback origin: new WebSocket('ws://127.0.0.1:8088/api/v1/events?token='+leakedToken) — confirm operator-side run events stream out cross-origin."
}

