record_exploration_finding
{
  "path": "crates/nyx-agent-api/src/router.rs",
  "line": 887,
  "cap": "CSRF",
  "endpoint": "POST /api/v1/scan?repo=&token= (also /quarantine/:id/promote, /quarantine/:id/dismiss)",
  "rationale": "trigger_scan takes only Query parameters — no JSON body required. From a browser's perspective this is a CORS *simple* request (POST + no custom headers + no body), so a cross-origin attacker page can fire it without preflight. The bearer can ride along in `?token=` (router.rs:116), which a victim's referrer/history may already have leaked. Result: any page the operator visits while logged in can spam scans (DoS via runaway repo clone/sandbox spin) or, against a misconfigured repo, force scan paths the operator did not initiate. Same shape applies to /quarantine/:id/promote and /quarantine/:id/dismiss. Static pass missed because the CSRF surface is the *absence* of (a) CorsLayer with credential-aware policy, (b) Origin/Sec-Fetch-Site checks, (c) anti-CSRF token — all missing controls.",
  "suggested_payload_hint": "<form method=POST action='http://127.0.0.1:8088/api/v1/scan?repo=victim-repo&token=LEAKED' enctype='text/plain'><input name=x value=y></form><script>document.forms[0].submit()</script>"
}

